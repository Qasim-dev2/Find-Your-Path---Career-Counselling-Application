<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend_of_project.Start">
    <children>
        <ImageView fx:id="image" fitHeight="488.0" fitWidth="800.0" layoutX="-2.0" layoutY="-1.0" pickOnBounds="true">
            <image>
                <Image url="@../Images/Top.jpg" />
            </image>
        </ImageView>
        <Button fx:id="button" alignment="CENTER" layoutX="179.0" layoutY="506.0" mnemonicParsing="false" onAction="#start" prefHeight="67.0" prefWidth="478.0" text="Tap to Continue" textAlignment="CENTER" textFill="#260000" textOverrun="CENTER_ELLIPSIS">
            <font>
                <Font name="Calisto MT Bold" size="25.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
